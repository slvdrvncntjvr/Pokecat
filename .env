# Pokecat environment variables
#
# TomTom API key used for the Map Display (night style tiles) and the Search API
# (reverse geocoding). Client-accessible via the EXPO_PUBLIC_ prefix (Expo SDK 57).
# Get a key at https://developer.tomtom.com/ and paste it after the = sign.
# When left blank the map shows a configuration message and catches store
# coordinates without a place name.
EXPO_PUBLIC_TOMTOM_API_KEY=
